{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://larksuite.local/svglide-contract-compile-report.schema.json",
  "title": "SVGlide contract compile page report",
  "type": "object",
  "required": [
    "version",
    "source",
    "semantic_map",
    "output",
    "status",
    "summary",
    "compiled",
    "degraded",
    "rasterized",
    "dropped",
    "blocking_issues",
    "input_sha256",
    "semantic_map_sha256",
    "output_sha256"
  ],
  "additionalProperties": true,
  "properties": {
    "version": {"const": "svglide-contract-compile/v1"},
    "source": {"type": "string", "minLength": 1},
    "semantic_map": {"type": "string", "minLength": 1},
    "output": {"type": "string", "minLength": 1},
    "status": {"enum": ["passed", "passed_with_warnings", "failed"]},
    "summary": {
      "type": "object",
      "required": [
        "semantic_required",
        "visual_required",
        "decorative_optional",
        "compiled_elements",
        "degraded_elements",
        "rasterized_regions",
        "dropped_decorations",
        "blocking_issues"
      ],
      "additionalProperties": true,
      "properties": {
        "semantic_required": {"type": "integer", "minimum": 0},
        "visual_required": {"type": "integer", "minimum": 0},
        "decorative_optional": {"type": "integer", "minimum": 0},
        "compiled_elements": {"type": "integer", "minimum": 0},
        "degraded_elements": {"type": "integer", "minimum": 0},
        "rasterized_regions": {"type": "integer", "minimum": 0},
        "dropped_decorations": {"type": "integer", "minimum": 0},
        "blocking_issues": {"type": "integer", "minimum": 0}
      }
    },
    "compiled": {"type": "array", "items": {
      "type": "object",
      "required": ["element_id", "importance", "decision", "reason"],
      "additionalProperties": true,
      "properties": {
        "element_id": {"type": "string", "minLength": 1},
        "source_ref": {"type": ["string", "null"]},
        "importance": {"enum": ["semantic_required", "visual_required", "decorative_optional"]},
        "source_tag": {"type": ["string", "null"]},
        "decision": {"enum": ["compiled", "degraded", "rasterized", "dropped", "blocked"]},
        "reason": {"type": "string", "minLength": 1},
        "output_ref": {"type": ["string", "null"]}
      }
    }},
    "degraded": {"type": "array", "items": {
      "type": "object",
      "required": ["element_id", "importance", "decision", "reason"],
      "additionalProperties": true,
      "properties": {
        "element_id": {"type": "string", "minLength": 1},
        "source_ref": {"type": ["string", "null"]},
        "importance": {"enum": ["semantic_required", "visual_required", "decorative_optional"]},
        "source_tag": {"type": ["string", "null"]},
        "decision": {"enum": ["compiled", "degraded", "rasterized", "dropped", "blocked"]},
        "reason": {"type": "string", "minLength": 1},
        "output_ref": {"type": ["string", "null"]}
      }
    }},
    "rasterized": {"type": "array", "items": {
      "type": "object",
      "required": ["element_id", "importance", "decision", "reason"],
      "additionalProperties": true,
      "properties": {
        "element_id": {"type": "string", "minLength": 1},
        "source_ref": {"type": ["string", "null"]},
        "importance": {"enum": ["semantic_required", "visual_required", "decorative_optional"]},
        "source_tag": {"type": ["string", "null"]},
        "decision": {"enum": ["compiled", "degraded", "rasterized", "dropped", "blocked"]},
        "reason": {"type": "string", "minLength": 1},
        "output_ref": {"type": ["string", "null"]}
      }
    }},
    "dropped": {"type": "array", "items": {
      "type": "object",
      "required": ["element_id", "importance", "decision", "reason"],
      "additionalProperties": true,
      "properties": {
        "element_id": {"type": "string", "minLength": 1},
        "source_ref": {"type": ["string", "null"]},
        "importance": {"enum": ["semantic_required", "visual_required", "decorative_optional"]},
        "source_tag": {"type": ["string", "null"]},
        "decision": {"enum": ["compiled", "degraded", "rasterized", "dropped", "blocked"]},
        "reason": {"type": "string", "minLength": 1},
        "output_ref": {"type": ["string", "null"]}
      }
    }},
    "blocking_issues": {"type": "array", "items": {
      "type": "object",
      "required": ["element_id", "importance", "decision", "reason"],
      "additionalProperties": true,
      "properties": {
        "element_id": {"type": "string", "minLength": 1},
        "source_ref": {"type": ["string", "null"]},
        "importance": {"enum": ["semantic_required", "visual_required", "decorative_optional"]},
        "source_tag": {"type": ["string", "null"]},
        "decision": {"enum": ["compiled", "degraded", "rasterized", "dropped", "blocked"]},
        "reason": {"type": "string", "minLength": 1},
        "output_ref": {"type": ["string", "null"]}
      }
    }},
    "input_sha256": {"type": "string", "minLength": 1},
    "semantic_map_sha256": {"type": "string", "minLength": 1},
    "output_sha256": {"type": "string", "minLength": 1}
  }
}
