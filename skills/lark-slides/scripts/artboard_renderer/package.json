{
  "name": "@larksuite/svglide-artboard-renderer",
  "version": "0.0.0-p0",
  "private": true,
  "type": "module",
  "scripts": {
    "render": "node render.mjs",
    "build": "esbuild render.mjs --bundle --platform=node --format=esm --target=node18 --external:@resvg/resvg-js --outfile=dist/render.mjs",
